PORT=3000

# Escolhe UMA das linhas DATABASE_URL (comenta a outra).
# Palavra-passe com caracteres especiais na URL: codificar (ex.: @ -> %40).

# PostgreSQL local (Windows, porta 5432) — cria antes: CREATE DATABASE biblioteca_livros;
# DATABASE_URL="postgresql://postgres:SENHA@127.0.0.1:5432/biblioteca_livros?schema=public"

# Docker Compose (porta 5433; docker compose up -d)
DATABASE_URL="postgresql://postgres:biblioteca_dev_local@127.0.0.1:5433/biblioteca_livros?schema=public"
